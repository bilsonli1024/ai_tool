# =====================================================
# 前端环境变量配置
# 复制此文件为 .env（本地开发）或 .env.production（生产部署）
# =====================================================

# 前端开发服务器端口（默认 5173）
VITE_DEV_PORT=5173

# 后端 API 代理目标（仅开发环境 Vite proxy 使用）
# 改为服务器地址后，npm run dev 时请求会转发到该地址
VITE_PROXY_TARGET=http://localhost:3001

# 后端 API 地址（生产环境必填；开发环境留空则使用 Vite proxy）
# 本地开发：留空（使用代理，避免跨域）
# 服务器部署：填写后端完整地址，例如 http://1.2.3.4:3001 或 https://api.yourdomain.com
VITE_API_BASE_URL=

