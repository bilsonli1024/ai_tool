# =====================================================
# 后端环境变量配置
# 复制此文件为 .env，根据实际情况修改
# =====================================================

# ——— 服务器网络配置 ———

# 监听端口（默认 3001）
PORT=3001

# 监听地址（默认 0.0.0.0，监听所有网卡，服务器部署推荐）
# 本地仅自己访问可改为 127.0.0.1
HOST=0.0.0.0

# 允许跨域的前端地址（多个地址用英文逗号分隔，无空格）
# 本地开发：
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# 服务器部署示例（取消注释并修改）：
# CORS_ORIGINS=https://yourdomain.com,http://1.2.3.4:5173

# ——— AI 模型配置 ———
# ⚠️ 重要：API Key 必须配置在服务器环境变量中，不能从前端传递
# 前端页面可以选择模型，但 API Key 只能从服务器环境变量读取
# 系统会根据选择的模型/服务商自动使用对应的 API Key

# ===== 各服务商 API Key 配置 =====
# 根据前端选择的模型，系统会自动使用对应的 API Key

# Google Gemini API Key（用于 Gemini 模型）
# 获取地址：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy-your-gemini-api-key-here

# DeepSeek API Key（用于 DeepSeek 模型）
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# OpenAI API Key（用于 OpenAI 模型）
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# 通义千问 API Key（用于 Qwen 模型）
# 获取地址：https://bailian.console.aliyun.com/
QWEN_API_KEY=sk-your-qwen-api-key-here

# Kimi（月之暗面）API Key（用于 Moonshot 模型）
# 获取地址：https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=sk-your-moonshot-api-key-here

# 自定义接口 API Key（用于自定义 baseURL）
CUSTOM_API_KEY=sk-your-custom-api-key-here

# ===== 默认配置（可选，用于向后兼容） =====
# 如果未配置特定服务商的 Key，会尝试使用 OPENAI_API_KEY 作为降级方案
# API 接口地址（可选，前端可以选择不同的服务商）
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# 默认模型（可选，前端可以选择不同的模型）
OPENAI_MODEL=gemini-2.0-flash

# ===== 使用说明 =====
# 1. 至少配置一个服务商的 API Key（推荐配置 GEMINI_API_KEY）
# 2. 前端选择对应的模型时，系统会自动使用对应的 API Key
# 3. 如果某个服务商的 Key 未配置，会尝试使用 OPENAI_API_KEY 作为降级方案
# 4. 图片生成功能目前只支持 Gemini，需要配置 GEMINI_API_KEY
