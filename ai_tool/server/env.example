# =====================================================
# 后端环境变量配置
# 复制此文件为 .env，根据实际情况修改
# =====================================================

# ——— 服务器网络配置 ———

# 监听端口（默认 3001）
PORT=3001

# 监听地址（默认 0.0.0.0，监听所有网卡，服务器部署推荐）
# 本地仅自己访问可改为 127.0.0.1
HOST=0.0.0.0

# 允许跨域的前端地址（多个地址用英文逗号分隔，无空格）
# 本地开发：
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# 服务器部署示例（取消注释并修改）：
# CORS_ORIGINS=https://yourdomain.com,http://1.2.3.4:5173

# ——— AI 模型配置（默认 Google Gemini） ———

# API Key（从 https://aistudio.google.com/app/apikey 获取）
OPENAI_API_KEY=AIzaSy-your-gemini-api-key-here

# API 接口地址
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# 默认模型
OPENAI_MODEL=gemini-2.0-flash

# ——— 切换为其他模型 ———
# DeepSeek：
# OPENAI_API_KEY=sk-xxxx
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_MODEL=deepseek-chat
#
# OpenAI：
# OPENAI_API_KEY=sk-xxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
